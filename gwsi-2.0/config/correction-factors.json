  "bonus_factors": {
    "description": "根据市场特殊优势的加分项",
    "structure": "综合修正系数 = 基础修正系数 × ∏(1 + 各增分项)",
    "factors": [
      {
        "id": "bf_01",
        "name": "风资源优势",
        "english_name": "Wind Resource Advantage",
        "max_bonus": 0.2,
        "description": "市场拥有充足的风资源，便于大规模开发",
        "trigger_conditions": [
          {
            "metric": "平均风速",
            "threshold": 7.5,
            "unit": "m/s",
            "bonus": 0.15
          },
          {
            "metric": "年均发电小时数",
            "threshold": 2500,
            "unit": "小时",
            "bonus": 0.1
          },
          {
            "metric": "风资源品质等级",
            "threshold": "I级",
            "unit": "等级",
            "bonus": 0.2
          }
        ],
        "calculation": "max(所有满足条件的bonus)",
        "notes": "可多个条件同时满足，取最高值"
      },
      {
        "id": "bf_02",
        "name": "电网友好性",
        "english_name": "Grid Friendliness",
        "max_bonus": 0.2,
        "description": "电网对风电消纳和并网的友好程度",
        "trigger_conditions": [
          {
            "metric": "消纳率",
            "threshold": 95,
            "unit": "%",
            "bonus": 0.15
          },
          {
            "metric": "电网稳定性指数",
            "threshold": 0.95,
            "unit": "指数",
            "bonus": 0.1
          },
          {
            "metric": "并网周期",
            "threshold": 6,
            "unit": "月",
            "bonus": 0.12,
            "inverse": true
          }
        ],
        "calculation": "max(所有满足条件的bonus)",
        "notes": "反向指标（并网周期）：越短越好"
      },
      {
        "id": "bf_03",
        "name": "产业成熟度",
        "english_name": "Industry Maturity",
        "max_bonus": 0.2,
        "description": "市场风电产业链配套和人才储备的成熟程度",
        "trigger_conditions": [
          {
            "metric": "产业链完整度",
            "threshold": 80,
            "unit": "%",
            "bonus": 0.12
          },
          {
            "metric": "技术人才数量",
            "threshold": 1000,
            "unit": "人",
            "bonus": 0.1
          },
          {
            "metric": "本地供应商数量",
            "threshold": 50,
            "unit": "家",
            "bonus": 0.08
          },
          {
            "metric": "R&D投入占比",
            "threshold": 3,
            "unit": "%",
            "bonus": 0.15
          }
        ],
        "calculation": "sum(所有满足条件的bonus) 但不超过max_bonus",
        "notes": "可多个条件累加，但总和不超过0.2"
      }
    ]
  },
  "comprehensive_benefit_rate": {
    "description": "综合回报率（最终修正系数）的计算",
    "formula": "修正系数 = 基础修正系数 × ∏(1 + 各增分项)",
    "example": {
      "base_coefficient": 1.0,
      "bonus_wind_resource": 0.15,
      "bonus_grid_friendly": 0.1,
      "bonus_industry_maturity": 0.08,
      "calculation": "1.0 × (1+0.15) × (1+0.1) × (1+0.08) = 1.358",
      "result": 1.358,
      "note": "实际结果将被限制在 0.4-1.2 的范围内，所以最终为 1.2"
    },
    "range": {
      "min": 0.4,
      "typical_min": 0.6,
      "typical_max": 1.1,
      "max": 1.2,
      "description": "综合修正系数的有效范围"
    }
  },
